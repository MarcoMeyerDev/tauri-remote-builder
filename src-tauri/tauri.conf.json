{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri Remote Builder",
  "version": "0.1.0",
  "identifier": "com.marcomeyerdev.tauriremote.builder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri Remote Builder",
        "width": 900,
        "height": 620,
        "minWidth": 680,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
